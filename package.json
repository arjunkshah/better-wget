{
  "name": "cleanscrape",
  "version": "0.1.3",
  "description": "Clean frontend extractor: convert live sites into editable HTML/CSS/assets",
  "type": "module",
  "bin": {
    "cleanscrape": "dist/cli.js",
    "scraper": "dist/cli.js",
    "scrapify": "dist/cli.js",
    "better-wget": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node dist/cli.js run ./output --port 4173",
    "dev:cli": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "wget",
    "curl",
    "scraping",
    "frontend",
    "playwright"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cheerio": "^1.0.0",
    "commander": "^14.0.0",
    "prettier": "^3.6.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
